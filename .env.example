# .env.example — copy to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# ── GitHub tokens (generate at github.com/settings/tokens) ──────────────────
VITE_GH_PERSONAL_TOKEN=your_personal_github_token_here
VITE_GH_OFFICE_TOKEN=your_office_github_token_here

# ── Google OAuth (Google Cloud → APIs & Services → Credentials) ──────────────
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Piku identity (used for Gmail, Calendar, GitHub account seeding) ─────────
VITE_PIKU_WORK_EMAIL=work@example.com
VITE_PIKU_PERSONAL_EMAIL=personal@example.com
VITE_PIKU_WORK_GH=work-user
VITE_PIKU_PERSONAL_GH=personal-user
